# =============================================================================
# Aquifer — Environment Variables
# =============================================================================
# Copy to .env and fill in your values.
# Only DATABASE_URL + embedding config are required for basic MCP recall.

# ---------------------------------------------------------------------------
# Database (REQUIRED)
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/mydb

# PG schema name — all Aquifer tables live under this schema (default: aquifer)
# AQUIFER_SCHEMA=aquifer

# Multi-tenant isolation key (default: default)
# AQUIFER_TENANT_ID=default

# ---------------------------------------------------------------------------
# Embedding (REQUIRED for recall)
# ---------------------------------------------------------------------------
# Any OpenAI-compatible endpoint works: Ollama, vLLM, OpenRouter, OpenAI, etc.
AQUIFER_EMBED_BASE_URL=http://localhost:11434/v1
AQUIFER_EMBED_MODEL=bge-m3

# API key — required for hosted providers, not needed for local Ollama
# AQUIFER_EMBED_API_KEY=

# Embedding dimension hint — auto-detected if omitted
# AQUIFER_EMBED_DIM=1024

# ---------------------------------------------------------------------------
# LLM (OPTIONAL — needed for built-in summarization during enrich)
# ---------------------------------------------------------------------------
# Without this, you must provide your own summaryFn to enrich().
# AQUIFER_LLM_BASE_URL=http://localhost:11434/v1
# AQUIFER_LLM_MODEL=llama3.1
# AQUIFER_LLM_API_KEY=

# ---------------------------------------------------------------------------
# Entities / Knowledge Graph (OPTIONAL)
# ---------------------------------------------------------------------------
# AQUIFER_ENTITIES_ENABLED=true
# AQUIFER_ENTITY_SCOPE=default

# ---------------------------------------------------------------------------
# Reranker (OPTIONAL — cross-encoder reranking for better precision)
# ---------------------------------------------------------------------------
# Providers: tei, jina, openrouter
# AQUIFER_RERANK_ENABLED=false
# AQUIFER_RERANK_PROVIDER=tei
# AQUIFER_RERANK_BASE_URL=http://localhost:8080
# AQUIFER_RERANK_API_KEY=
# AQUIFER_RERANK_MODEL=
# AQUIFER_RERANK_TOP_K=20

# ---------------------------------------------------------------------------
# Default agent/source (OPTIONAL)
# ---------------------------------------------------------------------------
# AQUIFER_AGENT_ID=main
# AQUIFER_SOURCE=api
